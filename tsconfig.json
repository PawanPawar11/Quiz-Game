{
  "compilerOptions": {
    "target": "es6",
    "module": "es2020",
    "lib": ["dom", "es2020"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "rootDir": "./",
    "outDir": "./"
  },
  "include": ["script.ts"],
  "exclude": ["node_modules"]
}